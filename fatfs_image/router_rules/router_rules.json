[
  {
    "id": "relay_oled_service_startup",
    "description": "Start the relay/button/OLED background service after boot.",
    "enabled": true,
    "consume_on_match": false,
    "ack": "relay oled service startup",
    "match": {
      "event_type": "startup",
      "event_key": "boot_completed"
    },
    "actions": [
      {
        "type": "run_script",
        "input": {
          "path": "user/relay_oled_service.lua",
          "async": true,
          "name": "relay_oled_service",
          "exclusive": "relay_oled_service",
          "replace": true,
          "args": {
            "relay_gpio": 4,
            "relay_active_level": 1,
            "button_gpio": 5,
            "button_active_level": 0,
            "i2c_port": 0,
            "i2c_sda": 8,
            "i2c_scl": 9,
            "i2c_freq_hz": 400000,
            "oled_addr": 60,
            "oled_width": 128,
            "oled_height": 64,
            "enable_oled": true,
            "default_on": false,
            "poll_ms": 50,
            "status_refresh_ms": 1000
          }
        }
      }
    ]
  },
  {
    "id": "telegram_relay_on",
    "description": "Turn the relay on from Telegram.",
    "enabled": true,
    "consume_on_match": true,
    "ack": "telegram relay on",
    "match": {
      "event_type": "message",
      "event_key": "text",
      "source_channel": "telegram",
      "content_type": "text",
      "text": "/relay on"
    },
    "actions": [
      {
        "type": "run_script",
        "input": {
          "path": "user/relay_oled_command.lua",
          "args": {
            "action": "on",
            "relay_gpio": 4,
            "button_gpio": 5,
            "i2c_port": 0,
            "i2c_sda": 8,
            "i2c_scl": 9,
            "oled_addr": 60,
            "enable_oled": true
          }
        }
      },
      {
        "type": "send_message",
        "input": {
          "channel": "{{event.source_channel}}",
          "chat_id": "{{event.chat_id}}"
        }
      }
    ]
  },
